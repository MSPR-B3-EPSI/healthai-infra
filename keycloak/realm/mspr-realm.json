{
  "realm": "healthai",
  "roles": {
    "realm": [
      { "name": "plan-freemium" },
      { "name": "plan-premium" },
      { "name": "plan-premium+" }
    ]
  },
  "clientScopes": [
    {
      "name": "api-all-access",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "multi-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "aud",
            "claim.value": "healthbook-api, tracking-api, data-recommendation-api",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "roles",
    "api-all-access"
  ]
}