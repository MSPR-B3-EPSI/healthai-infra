        "justifyMode": "center",
        "text": {}
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({compose_service=~\".+\",compose_service!~\"loki|promtail|grafana|prometheus\"} |~ \"(?i)(error|exception|fatal|panic)\" [5m]))",
