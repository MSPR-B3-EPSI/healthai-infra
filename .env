# Gateway and tooling ports
GATEWAY_PORT=8080
AIRFLOW_PORT=8081
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# Local source checkouts for hot reload development
MSPR_API_SOURCE_DIR=../healthbook-api
MSPR_TRACKING_SOURCE_DIR=../tracking-api
MSPR_DATA_SOURCE_DIR=../data-recommendation-api
MSPR_BRAIN_NEST_SOURCE_DIR=../healthai-brain-api/exposed-nest-api
MSPR_BRAIN_FASTAPI_SOURCE_DIR=../healthai-brain-api/hidden-fastapi

# Dev watch commands for the service containers
MSPR_API_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && npx prisma migrate deploy && exec node_modules/.bin/nest start --watch
MSPR_TRACKING_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && npx prisma migrate deploy && exec node_modules/.bin/nest start --watch
MSPR_DATA_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && npx prisma migrate deploy && exec node_modules/.bin/nest start --watch
MSPR_BRAIN_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && npx prisma migrate deploy && exec node_modules/.bin/nest start --watch
MSPR_BRAIN_FASTAPI_DEV_COMMAND=if [ ! -f .venv/bin/uvicorn ]; then python -m venv .venv && .venv/bin/pip install -r requirements.txt; fi && exec .venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --reload

# Runtime
NODE_ENV=development

# Keycloak
KEYCLOAK_REALM=healthai
KEYCLOAK_ISSUER_EXTERNAL=http://localhost:8080/auth/realms/healthai
KEYCLOAK_ISSUER_INTERNAL=http://keycloak:8080/auth/realms/healthai
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak DB (dev only)
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=change-me

# API DB (dev only)
API_POSTGRES_DB=api
API_POSTGRES_USER=api
API_POSTGRES_PASSWORD=change-me
API_DATABASE_URL=postgresql://api:change-me@postgres_api:5432/api

# Tracking DB (dev only)
TRACKING_POSTGRES_DB=tracking
TRACKING_POSTGRES_USER=tracking
TRACKING_POSTGRES_PASSWORD=change-me
TRACKING_DATABASE_URL=postgresql://tracking:change-me@postgres_tracking:5432/tracking

# Data DB (dev only)
DATA_POSTGRES_DB=data
DATA_POSTGRES_USER=data
DATA_POSTGRES_PASSWORD=change-me
DATA_DATABASE_URL=postgresql://data:change-me@postgres_data:5432/data

BRAIN_POSTGRES_DB=brain
BRAIN_POSTGRES_USER=brain
BRAIN_POSTGRES_PASSWORD=change-me
BRAIN_DATABASE_URL=postgresql://brain:change-me@postgres_brain:5432/brain

# Service audiences — must match the audience mapper values in healthai-realm.json
KEYCLOAK_AUDIENCE_API=healthbook-api
KEYCLOAK_AUDIENCE_TRACKING=tracking-api
KEYCLOAK_AUDIENCE_DATA=data-recommendation-api
KEYCLOAK_AUDIENCE_BRAIN=healthai-brain-api

# Airflow DB + admin (dev only)
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change-me
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ClickHouse (deep-data profile)
# Port host 9000 conflit avec Authentik sur le raspberry → on remappe en 9002.
# Le port INTERNE container reste 9000 (les services parlent à `clickhouse:9000`
# via le réseau Docker, donc le code Airflow / FastAPI n'est pas impacté).
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
CLICKHOUSE_PASSWORD=change-me

# MinIO (deep-data profile)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9001

# Reverse proxy via Nginx + Cloudflare → healthai.chomizzz.fr
PUBLIC_URL=https://healthai.chomizzz.fr

# Airflow
AIRFLOW_BASE_URL=https://healthai.chomizzz.fr/airflow
AIRFLOW_ENABLE_PROXY_FIX=True

# Keycloak
KC_HOSTNAME=healthai.chomizzz.fr
KC_HOSTNAME_PORT=443

# MinIO console
MINIO_BROWSER_REDIRECT_URL=https://healthai.chomizzz.fr/minio

# Grafana
GF_SERVER_ROOT_URL=https://healthai.chomizzz.fr/grafana
GF_SERVER_SERVE_FROM_SUB_PATH=true

# Prometheus
PROMETHEUS_EXTERNAL_URL=https://healthai.chomizzz.fr/prometheus
PROMETHEUS_ROUTE_PREFIX=/prometheus
