meta {
  name: healthai
  type: collection
  version: 1
}

auth {
  mode: oauth2
}

auth:oauth2 {
  grant_type: authorization_code
  callback_url: http://localhost:9999/
  authorization_url: {{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/auth
  access_token_url: {{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token
  client_id: {{client_id}}
  client_secret:
  scope: openid
  pkce: true
}
