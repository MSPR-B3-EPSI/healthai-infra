# Namespace
ORG_NAME=your-org

# Gateway and tooling ports
GATEWAY_PORT=8080
AIRFLOW_PORT=8081
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Service image references (set valid tags before running services)
MSPR_API_IMAGE=ghcr.io/${ORG_NAME}/mspr-api:latest
MSPR_TRACKING_IMAGE=ghcr.io/${ORG_NAME}/mspr-tracking:latest
MSPR_DATA_IMAGE=ghcr.io/${ORG_NAME}/mspr-data:latest

# Local source checkouts for hot reload development
MSPR_API_SOURCE_DIR=../mspr-api
MSPR_TRACKING_SOURCE_DIR=../mspr-tracking
MSPR_DATA_SOURCE_DIR=../mspr-data

# Dev watch commands for the service containers
MSPR_API_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm ci; fi && npm run start:dev
MSPR_TRACKING_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm ci; fi && npm run start:dev
MSPR_DATA_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm ci; fi && npm run start:dev

# Runtime
NODE_ENV=development

# Keycloak
KEYCLOAK_REALM=mspr
KEYCLOAK_ISSUER_INTERNAL=http://keycloak:8080/realms/mspr
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak DB (dev only)
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=change-me

# API DB (dev only)
API_POSTGRES_DB=api
API_POSTGRES_USER=api
API_POSTGRES_PASSWORD=change-me
API_DATABASE_URL=postgresql://api:change-me@postgres_api:5432/api

# Tracking DB (dev only)
TRACKING_POSTGRES_DB=tracking
TRACKING_POSTGRES_USER=tracking
TRACKING_POSTGRES_PASSWORD=change-me
TRACKING_DATABASE_URL=postgresql://tracking:change-me@postgres_tracking:5432/tracking

# Data DB (dev only)
DATA_POSTGRES_DB=data
DATA_POSTGRES_USER=data
DATA_POSTGRES_PASSWORD=change-me
DATA_DATABASE_URL=postgresql://data:change-me@postgres_data:5432/data

# Optional warehouse DB placeholder (not provisioned by default)
WAREHOUSE_POSTGRES_DB=warehouse
WAREHOUSE_POSTGRES_USER=warehouse
WAREHOUSE_POSTGRES_PASSWORD=change-me

# Service audiences
KEYCLOAK_AUDIENCE_API=mspr-api
KEYCLOAK_AUDIENCE_TRACKING=mspr-tracking
KEYCLOAK_AUDIENCE_DATA=mspr-data

# Airflow DB + admin (dev only)
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change-me
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# MinIO (optional, dev only)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio
