# Gateway and tooling ports
GATEWAY_PORT=8080
AIRFLOW_PORT=8081
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# Local source checkouts for hot reload development
MSPR_API_SOURCE_DIR=../healthbook-api
MSPR_TRACKING_SOURCE_DIR=../tracking-api
MSPR_DATA_SOURCE_DIR=../data-recommendation-api

# Dev watch commands for the service containers
MSPR_API_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && exec node_modules/.bin/nest start --watch
MSPR_TRACKING_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && exec node_modules/.bin/nest start --watch
MSPR_DATA_DEV_COMMAND=if [ ! -d node_modules/.bin ]; then npm install; fi && npx prisma generate && exec node_modules/.bin/nest start --watch

# Runtime
NODE_ENV=development

# Keycloak
KEYCLOAK_REALM=healthai
KEYCLOAK_ISSUER_EXTERNAL=http://localhost:8080/auth/realms/healthai
KEYCLOAK_ISSUER_INTERNAL=http://keycloak:8080/auth/realms/healthai
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak DB (dev only)
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=change-me

# API DB (dev only)
API_POSTGRES_DB=api
API_POSTGRES_USER=api
API_POSTGRES_PASSWORD=change-me
API_DATABASE_URL=postgresql://api:change-me@postgres_api:5432/api

# Tracking DB (dev only)
TRACKING_POSTGRES_DB=tracking
TRACKING_POSTGRES_USER=tracking
TRACKING_POSTGRES_PASSWORD=change-me
TRACKING_DATABASE_URL=postgresql://tracking:change-me@postgres_tracking:5432/tracking

# Data DB (dev only)
DATA_POSTGRES_DB=data
DATA_POSTGRES_USER=data
DATA_POSTGRES_PASSWORD=change-me
DATA_DATABASE_URL=postgresql://data:change-me@postgres_data:5432/data


# Service audiences — must match the audience mapper values in healthai-realm.json
KEYCLOAK_AUDIENCE_API=healthbook-api
KEYCLOAK_AUDIENCE_TRACKING=tracking-api
KEYCLOAK_AUDIENCE_DATA=data-recommendation-api

# Airflow DB + admin (dev only)
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change-me
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

